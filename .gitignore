# ────────────────────────────────────────────────────────────────
# Terraform
# ────────────────────────────────────────────────────────────────

# Local .terraform directories (any depth — applies to every module)
**/.terraform/*

# State files (never commit these — remote state only)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan output files (binary, not meant for source control)
*.tfplan
*.plan

# Crash logs
crash.log
crash.*.log

# Variable files — may contain secrets or environment-specific values.
# The *.example templates are allow-listed so users know what to override.
*.tfvars
*.tfvars.json
!*.tfvars.example
!terraform.tfvars.example

# Override files (meant for local dev overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Lock file — kept committed in this repo for reproducibility.
# Uncomment the next line if you'd rather ignore it.
# .terraform.lock.hcl

# ────────────────────────────────────────────────────────────────
# Secrets & credentials
# ────────────────────────────────────────────────────────────────

# Env files commonly used for TF_VAR_* exports
.env
.env.*
!.env.example

# Certificates and private keys
*.pem
*.key
*.pfx
*.p12
*.cer

# ────────────────────────────────────────────────────────────────
# OS / editor noise
# ────────────────────────────────────────────────────────────────

.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
